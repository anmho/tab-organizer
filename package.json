{
  "name": "tab-organizer-plasmo",
  "version": "1.0.0",
  "description": "Chrome side panel extension to organize tabs, dedupe, and clean old tabs.",
  "author": "",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.288",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.27",
    "plasmo": "^0.90.5",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.2"
  },
  "manifest": {
    "name": "Tab Tidy Side Panel",
    "permissions": [
      "favicon",
      "sessions",
      "tabs",
      "tabGroups",
      "storage"
    ],
    "minimum_chrome_version": "116",
    "action": {
      "default_title": "Open Tab Tidy"
    }
  }
}
